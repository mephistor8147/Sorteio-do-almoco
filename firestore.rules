rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: queue
    // Fields: id, name, position, photoUrl, isActive
    //
    // Collection: settings
    // Fields: heroTitleLine1, heroTitleLine2, heroSubtitle, heroDescription, lotteryTime, lotteryDays, etc.
    //
    // Collection: history
    // Fields: id, timestamp, winnerName, winnerId, fullList
    //
    // Collection: admins
    // Fields: id, name, email, isActive, createdAt, password, photoUrl
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isFullAdmin() {
      return isAuthenticated() && 
             request.auth.token.email != null &&
             (request.auth.token.email.lower() == "l2xbrasil@gmail.com" || 
              request.auth.token.email.lower() == "sorteioadm@sorteio.com" ||
              (exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())) && 
               get(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())).data.isActive == true &&
               get(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())).data.role == 'admin'));
    }

    function isAtLeastCoordinator() {
      return isAuthenticated() && 
             request.auth.token.email != null &&
             (request.auth.token.email.lower() == "l2xbrasil@gmail.com" || 
              request.auth.token.email.lower() == "sorteioadm@sorteio.com" ||
              (exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())) && 
               get(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())).data.isActive == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function isValidEmployee() {
      return hasRequiredFields(['id', 'name', 'position', 'isActive']) &&
             hasOnlyAllowedFields(['id', 'name', 'position', 'isActive', 'photoUrl']) &&
             request.resource.data.id is string &&
             isValidString('name', 1, 100) &&
             request.resource.data.position is number &&
             request.resource.data.position >= 0 &&
             request.resource.data.isActive is bool;
    }

    function isValidSettings() {
      return hasRequiredFields(['heroTitleLine1', 'heroTitleLine2', 'heroSubtitle', 'heroDescription', 'lotteryTime', 'lotteryDays', 'headerTitleLine1', 'headerTitleLine2', 'headerSubtitle', 'queueTitleLine1', 'queueTitleLine2', 'queueSubtitle']) &&
             hasOnlyAllowedFields(['heroTitleLine1', 'heroTitleLine2', 'heroSubtitle', 'heroDescription', 'heroBackgroundImage', 'lotteryTime', 'lotteryDays', 'lastLotteryDate', 'headerTitleLine1', 'headerTitleLine2', 'headerSubtitle', 'queueTitleLine1', 'queueTitleLine2', 'queueSubtitle', 'downloadUrl', 'downloadFileName', 'endOfRoundPosition', 'currentCallPosition']) &&
             request.resource.data.lotteryTime is string &&
             request.resource.data.lotteryTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$') &&
             request.resource.data.lotteryDays is list;
    }

    match /queue/{employeeId} {
      allow read: if true;
      allow create, update: if isAtLeastCoordinator() && isValidEmployee();
      allow delete: if isAtLeastCoordinator();
    }

    match /settings/global {
      allow read: if true;
      allow create, update: if isAtLeastCoordinator() && isValidSettings();
      allow delete: if isAtLeastCoordinator();
    }

    match /history/{historyId} {
      allow read: if true;
      allow create: if isAtLeastCoordinator();
      allow delete: if isAtLeastCoordinator();
    }

    match /file_history/{historyId} {
      allow read: if true;
      allow create, delete: if isAtLeastCoordinator();
    }

    match /admins/{adminEmail} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isFullAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
