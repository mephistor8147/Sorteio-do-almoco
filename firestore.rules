rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: queue
    // Fields: id, name, position, photoUrl, isActive
    //
    // Collection: settings
    // Fields: heroTitleLine1, heroTitleLine2, heroSubtitle, heroDescription, lotteryTime, lotteryDays, etc.
    //
    // Collection: history
    // Fields: id, timestamp, winnerName, winnerId, fullList
    //
    // Collection: admins
    // Fields: id, name, email, isActive, createdAt, password, photoUrl
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function isHardcodedAdmin() {
      return isAuthenticated() && 
             request.auth.token.email != null && 
             (request.auth.token.email.toLower() == "l2xbrasil@gmail.com".toLower() || 
              request.auth.token.email.toLower() == "sorteioadm@sorteio.com".toLower());
    }

    function isFullAdmin() {
      return isAuthenticated() && 
             (isHardcodedAdmin() ||
              (request.auth.token.email != null &&
               exists(/databases/$(database)/documents/admins/$(request.auth.token.email.toLower())) && 
               get(/databases/$(database)/documents/admins/$(request.auth.token.email.toLower())).data.isActive == true &&
               get(/databases/$(database)/documents/admins/$(request.auth.token.email.toLower())).data.role == 'admin'));
    }

    function isAtLeastCoordinator() {
      return isAuthenticated() && 
             (isHardcodedAdmin() || 
              (request.auth.token.email != null &&
               exists(/databases/$(database)/documents/admins/$(request.auth.token.email.toLower())) && 
               get(/databases/$(database)/documents/admins/$(request.auth.token.email.toLower())).data.isActive == true));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidEmployee(data) {
      return data.keys().hasAll(['id', 'name', 'position', 'isActive']) &&
             data.keys().size() <= 5 && // id, name, position, isActive, photoUrl
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 200 &&
             data.position is number &&
             data.isActive is bool &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 2000));
    }

    function isValidSettings(data) {
      // Basic keys check - making it more flexible to allow additional fields like lastLotteryTimestamp
      return data.keys().hasAll(['lotteryTime', 'lotteryDays', 'lotteryEnabled']) &&
             data.lotteryTime is string &&
             data.lotteryTime.matches('^([0-1]?[0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?$') &&
             data.lotteryDays is list &&
             data.lotteryEnabled is bool;
    }

    match /queue/{employeeId} {
      allow get, list: if true;
      allow create: if isAtLeastCoordinator() && isValidId(employeeId) && isValidEmployee(incoming());
      allow update: if isAtLeastCoordinator() && isValidEmployee(incoming()) && 
                    incoming().id == existing().id; // ID must be immutable
      allow delete: if isAtLeastCoordinator();
    }

    match /settings/global {
      allow get: if true;
      allow create, update: if isAtLeastCoordinator() && isValidSettings(incoming());
      allow delete: if isAtLeastCoordinator();
    }

    match /history/{historyId} {
      allow get, list: if true;
      allow create: if isAtLeastCoordinator() && isValidId(historyId);
      allow delete: if isAtLeastCoordinator();
    }

    match /file_history/{historyId} {
      allow get, list: if true;
      allow create, delete: if isAtLeastCoordinator() && isValidId(historyId);
    }

    match /admins/{adminEmail} {
      allow get: if isAuthenticated();
      allow list: if isAtLeastCoordinator();
      allow create, update, delete: if isFullAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow write: if isFullAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
