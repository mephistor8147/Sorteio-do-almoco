{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "An employee in the gourmet queue.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the employee."
        },
        "name": {
          "type": "string",
          "description": "Full name of the employee."
        },
        "position": {
          "type": "number",
          "description": "Current position in the queue."
        },
        "photoUrl": {
          "type": "string",
          "description": "URL of the employee's photo."
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the employee is active for the lottery."
        }
      },
      "required": ["id", "name", "position", "isActive"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "heroTitleLine1": {
          "type": "string"
        },
        "heroTitleLine2": {
          "type": "string"
        },
        "heroSubtitle": {
          "type": "string"
        },
        "heroDescription": {
          "type": "string"
        },
        "lotteryTime": {
          "type": "string",
          "format": "time"
        },
        "lotteryDays": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "lastLotteryDate": {
          "type": "string",
          "format": "date-time"
        },
        "headerTitleLine1": {
          "type": "string"
        },
        "headerTitleLine2": {
          "type": "string"
        },
        "headerSubtitle": {
          "type": "string"
        },
        "queueTitleLine1": {
          "type": "string"
        },
        "queueTitleLine2": {
          "type": "string"
        },
        "queueSubtitle": {
          "type": "string"
        }
      },
      "required": ["heroTitleLine1", "heroTitleLine2", "heroSubtitle", "heroDescription", "lotteryTime", "lotteryDays", "headerTitleLine1", "headerTitleLine2", "headerSubtitle", "queueTitleLine1", "queueTitleLine2", "queueSubtitle"]
    },
    "LotteryHistory": {
      "title": "LotteryHistory",
      "description": "A record of a past lottery draw.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "winnerName": {
          "type": "string"
        },
        "winnerId": {
          "type": "string"
        },
        "fullList": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "photoUrl": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "timestamp", "winnerName", "winnerId", "fullList"]
    }
  },
  "firestore": {
    "/queue/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of employees in the queue."
    },
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Global application settings document."
    },
    "/history/{historyId}": {
      "schema": "LotteryHistory",
      "description": "Collection of past lottery draws."
    }
  }
}
