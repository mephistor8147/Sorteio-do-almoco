{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "An employee in the gourmet queue.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the employee."
        },
        "name": {
          "type": "string",
          "description": "Full name of the employee."
        },
        "position": {
          "type": "number",
          "description": "Current position in the queue."
        },
        "photoUrl": {
          "type": "string",
          "description": "URL of the employee's photo."
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the employee is active for the lottery."
        }
      },
      "required": ["id", "name", "position", "isActive"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "heroTitleLine1": { "type": "string" },
        "heroTitleLine2": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroDescription": { "type": "string" },
        "heroBackgroundImage": { "type": "string" },
        "lotteryTime": { "type": "string", "format": "time" },
        "lotteryDays": { "type": "array", "items": { "type": "number" } },
        "lotteryEnabled": { "type": "boolean" },
        "lotteryEnabledBy": { "type": "string" },
        "lastLotteryDate": { "type": "string", "format": "date-time" },
        "downloadUrl": { "type": "string" },
        "downloadFileName": { "type": "string" },
        "headerTitleLine1": { "type": "string" },
        "headerTitleLine2": { "type": "string" },
        "headerSubtitle": { "type": "string" },
        "queueTitleLine1": { "type": "string" },
        "queueTitleLine2": { "type": "string" },
        "queueSubtitle": { "type": "string" },
        "endOfRoundPosition": { "type": "number" },
        "currentCallPosition": { "type": "number" },
        "voiceCallEnabled": { "type": "boolean" },
        "lastCalledEmployeeId": { "type": "string" },
        "lastCalledTimestamp": { "type": "string" },
        "publicShuffleEnabled": { "type": "boolean" },
        "publicShuffleStartTime": { "type": "string" },
        "publicShuffleEndTime": { "type": "string" }
      },
      "required": ["heroTitleLine1", "heroTitleLine2", "heroSubtitle", "heroDescription", "lotteryTime", "lotteryDays", "lotteryEnabled"]
    },
    "FileHistory": {
      "title": "FileHistory",
      "description": "A record of an uploaded file link.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "number" },
        "uploaderEmail": { "type": "string" },
        "downloadUrl": { "type": "string" }
      },
      "required": ["id", "timestamp", "fileName", "fileSize", "uploaderEmail", "downloadUrl"]
    },
    "LotteryHistory": {
      "title": "LotteryHistory",
      "description": "A record of a past lottery draw.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "winnerName": { "type": "string" },
        "winnerId": { "type": "string" },
        "fullList": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "photoUrl": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "timestamp", "winnerName", "winnerId", "fullList"]
    },
    "AdminUser": {
      "title": "AdminUser",
      "description": "An administrator user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "coordinator"] },
        "password": { "type": "string" },
        "photoUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "isActive", "createdAt"]
    },
    "UsernameMap": {
      "title": "UsernameMap",
      "description": "Mapping from username to email for login.",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/queue/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of employees in the queue."
    },
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Global application settings document."
    },
    "/history/{historyId}": {
      "schema": "LotteryHistory",
      "description": "Collection of past lottery draws."
    },
    "/file_history/{historyId}": {
      "schema": "FileHistory",
      "description": "Collection of past file uploads or links."
    },
    "/admins/{adminId}": {
      "schema": "AdminUser",
      "description": "Collection of administrator users."
    },
    "/usernames/{username}": {
      "schema": "UsernameMap",
      "description": "Safe public mapping for username-based login."
    }
  }
}
